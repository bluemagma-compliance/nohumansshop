# ─────────────────────────────────────────────────────────────────────────
# noHumansShop — ENV TEMPLATE (safe to commit; contains NO real secrets)
#
# HOW TO USE:
#   1. Copy this file to `.env.local`   →   cp .env.example .env.local
#   2. Fill `.env.local` with REAL values.
#   3. `.env.local` is gitignored and must NEVER be committed.
#
# RULE: anything prefixed NEXT_PUBLIC_ is shipped to the browser — put ONLY
# non-secret values there. Everything else is server-only and must stay secret.
#
# Auth stack: Better Auth (self-hosted) + Neon. Better Auth handles both the
# human Google SSO login AND the MCP authorization-server role (OAuth + DCR).
# ─────────────────────────────────────────────────────────────────────────

# --- Database: Neon Postgres ---------------------------------------------
# [SECRET] server-only. Get this from your Neon project dashboard.
# Better Auth also stores users/sessions/oauth here (same DB — one place).
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"

# --- Auth: Better Auth ----------------------------------------------------
# [SECRET] server-only. Signs/encrypts sessions & tokens.
# Generate:  openssl rand -base64 32
BETTER_AUTH_SECRET="REPLACE_WITH_RANDOM_32_PLUS_CHARS"

# Base URL Better Auth runs at. Local dev below; prod = https://nohumans.shop
BETTER_AUTH_URL="http://localhost:3000"

# --- Google SSO (OAuth app from Google Cloud) -----------------------------
# Created in Google Cloud → APIs & Services → Credentials → OAuth client (Web).
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID="REPLACE_ME.apps.googleusercontent.com"   # config (not highly secret)
GOOGLE_CLIENT_SECRET="REPLACE_ME"                          # [SECRET] server-only

# --- App ------------------------------------------------------------------
# Browser-exposed (non-secret). Base URL of the app.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Later (NOT needed for the auth / MCP / account milestone) ------------
# [SECRET] Only when we add document/vector search (embeddings).
# OPENAI_API_KEY="sk-REPLACE_ME"
