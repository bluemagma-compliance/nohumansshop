# ─────────────────────────────────────────────────────────────────────────
# noHumansShop — ENV TEMPLATE (safe to commit; contains NO real secrets)
#
#   cp .env.example .env.local   then fill .env.local (gitignored — never commit)
#   NEXT_PUBLIC_* is shipped to the browser — non-secrets only.
#
# Auth = WorkOS AuthKit (managed authorization server): one system for human
# login AND the agent MCP OAuth (login link + CIMD/DCR). Neon = database only.
# ─────────────────────────────────────────────────────────────────────────

# --- Database: Neon Postgres ---------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require"   # [SECRET]

# --- Auth: WorkOS AuthKit --------------------------------------------------
WORKOS_API_KEY="sk_test_REPLACE_ME"                 # [SECRET] server-only
WORKOS_CLIENT_ID="client_REPLACE_ME"                # not secret
WORKOS_COOKIE_PASSWORD="REPLACE_WITH_RANDOM_32+"    # [SECRET] openssl rand -base64 32
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"

# AuthKit domain (dashboard → Domains), used in MCP discovery metadata so agents
# know where to authorize. e.g. https://your-app.authkit.app
WORKOS_AUTHKIT_DOMAIN="https://REPLACE_ME.authkit.app"

# Audience for agent tokens — must match the Resource Indicator you add in
# WorkOS → Connect → Configuration.
WORKOS_MCP_RESOURCE="http://localhost:3000/api/mcp"

# --- App ------------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Embeddings: AWS Bedrock (Titan Text Embeddings v2, 1024 dims) --------
AWS_REGION="us-west-2"
AWS_ACCESS_KEY_ID="REPLACE_ME"            # [SECRET]
AWS_SECRET_ACCESS_KEY="REPLACE_ME"        # [SECRET]
BEDROCK_REGION="us-west-2"
BEDROCK_EMBED_MODEL_ID="amazon.titan-embed-text-v2:0"
# NOTE: requires Titan Text Embeddings model access enabled in the Bedrock console
# for this region. OPENAI_API_KEY is no longer used.
